<%layout("/layouts/boilerplate")%>
<body>
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1" style="margin-top:2rem !important;">
  <%for(let listing of alllisting){%>
  <a href="/listings/<%=listing._id%>" class="listing-link">
  <div class="card listing-card ">
    <img src="<%=listing.image.url%>" class="card-img-top" alt="Listing_images" style="height:20rem;">
  <div class="card-body">
    <p class="card-text"><b><%=listing.title%></b><br/>&#8377; <%=listing.price.toLocaleString("en-IN") %></p>
  </div>
  </div>
  </a>
   <%}%>
</div>

</body>
