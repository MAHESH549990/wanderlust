<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>All Listing</title>
</head>
<body>
  <h1>View All Listing</h1>
  <form method="get" action="/listing/new">
    <button>Create new listing</button>
  </form>
  <%for(let listing of alllisting){%>
  <div>
  <li><a href="/listing/<%=listing._id%>">Title: <%=listing.title%></a></li>
  </div>
 <%}%>
</body>
</html>