
<%layout("/layouts/boilerplate")%>
<body>
<div class="row mt-3">
  <div class="col-8 offset-4">
    <h1><b><%=listing.title%></b></h1>
  </div>
<div class="card listing-card col-6 offset-4">
  <img src="<%=listing.image.url%>" class="card-img-top" alt="Listing_image" style="height:20rem;">
    <div class="card-body">
        <%=listing.description%><br/>
        ₹ <%= listing.price.toLocaleString("en-IN") %><br/>
        <%= listing.location %><br/>
        <%= listing.country %>
    </p>
    </div>
</div>
<div class="btns">
<a href="/listings/<%= listing._id %>/edit" class="edit-btn btn col-1 offset-4">Edit</a>
<form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
  <button class="delete-btn btn offset-8">Delete</button>
</form>
</div>
</div>
<br/><br/>
<div class="col-8 offset-4">
  <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation" novalidate>
    <hr>
     <h3>Create Review</h3>
      <div>
        <label for="rating" class="form-label fs-5">Rating: </label>
        <input type="range" min="1" max="5" step="1" name="review[rating]" id="rating" class="form-range">
      </div>
      <div>
        <label class="form-label fs-5" for="comment">Comment: </label>
        <textarea type="text" name="review[comment]" class="form-control" id="comment" rows="6" required></textarea>
        <div class="invalid-feedback">Need comment for feedback</div>
      </div>
      <button class="btn btn-outline-dark mt-4">Submit</button>
  </form>

  <hr>
 <h3><b>All Reviews</b></h3>
  <div class="row">
  <%for(let review of listing.reviews){%>
    <div class="card p-3 mb-4 col-5 ms-4">
     <div class="card-body">
      <h5 class="card-title">Mahesh Bhatt</h5>
       <p class="card-text"><%=review.comment%></p>
       <%for(let i=0;i<review.rating;i++){%>
         <i class="fa-solid fa-star" style="color:rgb(241, 174, 5)"></i>
       <%}%>
        <div>
          <form action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to delete this review?');">
              <button class="btn btn-outline-danger mt-3">Delete</button>
          </form>
        </div>
     </div>
    </div>
  <%}%>
  </div>
</div>
<br/><br/>
</body>