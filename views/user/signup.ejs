<%layout("/layouts/boilerplate")%>
<div class="row mt-2">
   <div class="col-6 offset-3" >
    <h1>User SignUp for Wanderlust</h1>
    <form action="/signup" method="POST" class="needs-validation" novalidate>
        <div class="mb-3">
        <label for="username" class="form-label">Username:</label>
        <input
            type="text"
            name="username"
            placeholder="Enter your name"
            class="form-control"
            required
        >
        <div class="valid-feedback">Name looks good</div>
        <div class="invalid-feedback">Please enter Name</div>
        </div>


        <div class="mb-3">
        <label for="email" class="form-label">Email:</label>
        <input
            type="email"
            name="email"
            placeholder="Enter your email"
            class="form-control"
            required
        >
        <div class="valid-feedback">Email looks good</div>
        <div class="invalid-feedback">Please enter email</div>
        </div>


        <div class="mb-3">
        <label for="password" class="form-label">Password:</label>
        <input
            type="password"
            name="password"
            placeholder="Password"
            class="form-control"
            required
        >
        <div class="valid-feedback">Password looks good</div>
        <div class="invalid-feedback">Please enter password</div>
        </div>
        
         <button class="btn btn-outline-success">SignUp</button>

      </form>
    </div>
</div>